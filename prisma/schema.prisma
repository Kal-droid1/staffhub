generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STAFF
  MANAGER
  ADMIN
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT
  PERMISSION
  ANNUAL_LEAVE
  OTHER
}

model User {
  id          String             @id @default(uuid())
  name        String
  email       String             @unique
  password    String
  role        Role               @default(STAFF)
  department  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  attendance  AttendanceRecord[] @relation("UserAttendance")
  reviewed    AttendanceRecord[] @relation("ReviewedBy")
  leaveGrants LeaveGrant[]
}

model Settings {
  id         String @id @default("singleton")
  cutoffTime String @default("09:00")
}

model AttendanceRecord {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation("UserAttendance", fields: [userId], references: [id])
  date            DateTime         @db.Date
  signInTime      DateTime?
  requestedStatus AttendanceStatus @default(PRESENT)
  note            String?
  status          AttendanceStatus @default(PENDING)
  leaveTypeId     String?
  leaveType       LeaveType?       @relation(fields: [leaveTypeId], references: [id])
  batchId         String?
  reviewedById    String?
  reviewedBy      User?            @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  createdAt       DateTime         @default(now())

  @@unique([userId, date])
}

model LeaveType {
  id               String             @id @default(uuid())
  name             String             @unique
  isAnnualRecurring Boolean           @default(false)
  mappedStatus     AttendanceStatus
  defaultDays      Float              @default(20)
  createdAt        DateTime           @default(now())
  grants           LeaveGrant[]
  attendance       AttendanceRecord[]
}

model LeaveGrant {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  days        Float
  grantedDate DateTime  @db.Date
  note        String?
  expiresAt   DateTime? @db.Date
  createdAt   DateTime  @default(now())
}

model Holiday {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  name      String
  year      Int
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([date, name])
  @@index([year])
}
